# Create .gitignore file
cat > .gitignore << 'EOF'
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
env.bak/
venv.bak/
pythonenv*

# Database
*.db
*.sqlite
*.sqlite3
*.db-wal
*.db-shm
*.db-journal

# Flask
instance/
.webassets-cache
.env
.flaskenv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs
*.log
*.pid

# Local configuration
config.local.py
settings.local.py
.env.local

# Test files
.pytest_cache/
.coverage
htmlcov/

# Virtual Environment
venv/
venv_*/
lib/
lib64/
include/
bin/
share/

# Secret keys
*.key
*.pem
*.crt

# Backup files
*.bak
*.backup

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Application specific
finance.db
*.csv
*.xlsx
*.xls

# Cache
.cache/
*.cache
EOF