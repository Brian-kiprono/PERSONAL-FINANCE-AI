cat > .gitignore << 'EOF'
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
env.bak/
venv.bak/

# Database
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Flask
instance/
.webassets-cache

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
*.log
*.csv
*.xlsx

# Environment
.env
.env.local

# Testing
.pytest_cache/
.coverage
htmlcov/

# OS
Thumbs.db
Desktop.ini

# Project specific
static/uploads/
temp/
backup/
EOF
